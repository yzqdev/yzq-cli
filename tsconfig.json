{
  //https://www.typescriptlang.org/tsconfig#compilerOptions

  "compilerOptions": {
    "outDir": "dist",
    "module": "ESNext",
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "target": "ESNext",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "baseUrl": "./",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },"noEmit": true,
    "include": [
      "src/**/*",
      "bin/**/*",
      "*.ts",
      "*.d.ts"
    ],
    "exclude": [
      "node_modules",
      "dist"
    ],  "types": ["node"],
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  }
}
